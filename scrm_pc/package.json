{
  "name": "web-element",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --host 192.168.110.207 --port 8085",
    "dev:electron": "node scripts/build-electron.mjs --watch",
    "dev:electron:launch": "wait-on tcp:192.168.110.207:8085 file:electron-dist/main.cjs && node ./node_modules/cross-env/dist/bin/cross-env.js VITE_DEV_SERVER_URL=http://192.168.110.207:8085 electron electron-dist/main.cjs",
    "dev:desktop": "concurrently -k -s first \"npm:dev:web\" \"npm:dev:electron\" \"npm:dev:electron:launch\"",
    "build": "vue-tsc -b && vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:desktop": "npm run build && npm run build:electron",
    "preview": "vite preview",
    "preview:desktop": "npm run build:desktop && electron electron-dist/main.cjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.14.0",
    "mockjs": "^1.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "esbuild": "^0.27.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.12",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.8",
    "wait-on": "^8.0.5"
  }
}
